BackgroundFeatureList["knightly reputation"] = {
	description : "I was trained within a knightly order, martial fellowship, sacred guard, noble house, or sworn military tradition. My bearing, discipline, and reputation mark me as someone shaped by command, duty, and violence. Other knights, soldiers, nobles, clergy, and military officials may recognize my training, though their reaction depends on the order I served.",
	source : [["DA42BG", 1]]
};

