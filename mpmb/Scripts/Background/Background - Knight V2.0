	feature : "Knightly Reputation",
	trait : [
		"I still follow old battlefield habits even when no battle is near.",
		"I judge people by how they act when frightened.",
		"I keep my armor, weapons, and gear in careful order.",
		"I do not easily forgive broken promises.",
		"I am formal with strangers, even when I dislike them.",
		"I find comfort in watches, patrols, and routines.",
		"I rarely speak of the oath, order, or banner that shaped me.",
		"I protect others instinctively, even when I tell myself I do not care."
	],
	ideal : [
		["Duty", "Duty. A life without discipline collapses into chaos. (Lawful)"],
		["Freedom", "Freedom. No oath should become a chain around the soul. (Chaotic)"],
		["Protection", "Protection. Strength exists to shield those who cannot defend themselves. (Good)"],
		["Power", "Power. Titles, vows, and banners matter only if they make others obey. (Evil)"],
		["Survival", "Survival. Orders fall. Kingdoms burn. The living keep moving. (Neutral)"],
		["Redemption", "Redemption. My past is stained, but my next choice is still mine. (Any)"]
	],
	bond : [
		"I still carry the symbol of the order that shaped me.",
		"Someone from my former life is still searching for me.",
		"I owe my survival to a comrade, lover, mentor, or enemy.",
		"I know a secret that could ruin a noble house, temple, or military order.",
		"I failed someone I swore to protect.",
		"I seek the battlefield, relic, commander, or truth that changed my life."
	],
	flaw : [
		"I distrust anyone who speaks too proudly of honor.",
		"I answer shame with anger.",
		"I struggle to ask for help, even when I need it.",
		"I expect betrayal before kindness.",
		"I cannot ignore an insult to my courage or loyalty.",
		"I sometimes treat mercy as weakness."
	],
	lifestyle : "modest"
};
