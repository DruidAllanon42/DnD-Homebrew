	source : [["DA42BG", 1]],
	type : "origin",
	description : "My order framed me to preserve its reputation. I gain History and Celestial.",
	descriptionFull : "My order framed me to preserve its reputation.\nContact: Secret sympathizer inside the order. Item: Sealed accusation scroll or broken knightly insignia. RP Note: I instinctively distrust authority.",
	skills : ["History"],
	languageProfs : ["Celestial"],
	toNotesPage : [{
